{
  "// PHP Sniffer & Beautifier (valeryanm.vscode-phpsab)": "uses the project ruleset + local phpcs",
  "phpsab.snifferEnable": true,
  "phpsab.fixerEnable": true,
  "phpsab.standard": "phpcs.xml.dist",
  "phpsab.executablePathCS": "${workspaceFolder}/vendor/bin/phpcs",
  "phpsab.executablePathCBF": "${workspaceFolder}/vendor/bin/phpcbf",

  "// PHP Sniffer (wongjn.php-sniffer) — alternative extension": "",
  "phpSniffer.standard": "phpcs.xml.dist",
  "phpSniffer.executablesFolder": "vendor/bin/",

  "// Avoid Intelephense duplicating diagnostics it can't fix": "",
  "intelephense.diagnostics.undefinedFunctions": false
}
